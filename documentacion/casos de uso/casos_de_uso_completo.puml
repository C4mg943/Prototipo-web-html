@startuml casos_de_uso_completo

left to right direction

skinparam actorStyle awesome
skinparam packageStyle rectangle

skinparam usecase {
  BackgroundColor #F0F4FF
  BorderColor #3B5998
  FontSize 11
}

skinparam rectangle {
  BorderColor #CCCCCC
  FontSize 13
  FontStyle bold
}

actor "Estudiante" as Est
actor "Vigilante" as Vig
actor "Administrador" as Adm
actor "Sistema\nUniversidad" as Sis

rectangle "Sistema UniDeportes" {

  rectangle "Acceso al Sistema" #E8F0FE {
    usecase "CU-01\nIniciar sesión" as CU01
    usecase "CU-02\nRecuperar\ncontraseña" as CU02
  }

  rectangle "Consulta de Escenarios" #E6F4EA {
    usecase "CU-03\nConsultar disponibilidad\nde escenarios" as CU03
    usecase "CU-04\nConsultar ubicación\nde escenarios" as CU04
  }

  rectangle "Gestión de Reservas" #FEF7E0 {
    usecase "CU-05\nRealizar reserva" as CU05
    usecase "CU-06\nConsultar mis\nreservas" as CU06
    usecase "CU-07\nModificar reserva" as CU07
    usecase "CU-08\nCancelar reserva" as CU08
    usecase "CU-09\nSolicitar\nequipamiento" as CU09
  }

  rectangle "Monitoreo Operativo" #FCE8E6 {
    usecase "CU-10\nConsultar reservas\ndel día" as CU10
    usecase "CU-11\nVerificar cumplimiento\nde reserva" as CU11
    usecase "CU-12\nReportar disponibilidad\nde cancha" as CU12
    usecase "CU-13\nConsultar estado\nde reserva" as CU13
    usecase "CU-14\nRegistrar novedad\noperativa" as CU14
  }

  rectangle "Administración del Sistema" #F3E8FD {
    usecase "CU-15\nGestionar usuarios" as CU15
    usecase "CU-16\nGestionar escenarios\ny canchas" as CU16
    usecase "CU-17\nGestionar\ndisponibilidad" as CU17
    usecase "CU-18\nGenerar reportes" as CU18
    usecase "CU-19\nConfigurar parámetros\ninstitucionales" as CU19
    usecase "CU-20\nConsultar trazabilidad\nde operaciones" as CU20
  }

}

' ══════════════════════════════════
' ACTORES → CASOS DE USO
' ══════════════════════════════════

' ── Estudiante ──
Est --> CU01
Est --> CU03
Est --> CU04
Est --> CU05
Est --> CU06
Est --> CU07
Est --> CU08

' ── Vigilante ──
Vig --> CU01
Vig --> CU10
Vig --> CU11
Vig --> CU12

' ── Administrador ──
Adm --> CU01
Adm --> CU15
Adm --> CU16
Adm --> CU17
Adm --> CU18
Adm --> CU01

' ── Sistema Universidad (actor secundario) ──
CU13 <-- Sis
CU14 <-- Sis
CU19 <-- Sis
CU20 <-- Sis

' ══════════════════════════════════
' RELACIONES <<include>>
' ══════════════════════════════════

' Reservas: realizar incluye consultar disponibilidad
CU05 ..> CU03 : <<include>>

' Reservas: modificar y cancelar incluyen consultar reservas
CU07 ..> CU06 : <<include>>
CU08 ..> CU06 : <<include>>

' Monitoreo: consultar y verificar incluyen consultar estado
CU10 ..> CU13 : <<include>>
CU11 ..> CU13 : <<include>>

' Monitoreo: reportar incluye registrar novedad
CU12 ..> CU14 : <<include>>

' Admin: gestionar usuarios/escenarios/disponibilidad incluyen configurar parámetros
CU15 ..> CU19 : <<include>>
CU16 ..> CU19 : <<include>>
CU17 ..> CU19 : <<include>>

' Admin: generar reportes incluye consultar trazabilidad
CU18 ..> CU20 : <<include>>

' ══════════════════════════════════
' RELACIONES <<extend>>
' ══════════════════════════════════

' Recuperar contraseña extiende opcionalmente iniciar sesión
CU02 ..> CU01 : <<extend>>

' Solicitar equipamiento extiende opcionalmente realizar reserva
CU09 ..> CU05 : <<extend>>

@enduml
